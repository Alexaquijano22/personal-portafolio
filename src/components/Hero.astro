---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<section id="hero" class="bg-white">
  <div class="max-w-6xl mx-auto px-6 pt-32 pb-20 flex flex-col-reverse md:flex-row items-center gap-12 md:gap-16">

    <!-- Text -->
    <div class="flex-1 text-center md:text-left">
      <p class="text-body font-medium mb-3">¡Hola! Soy</p>
      <h1 class="text-5xl md:text-6xl lg:text-6xl font-extrabold text-primary leading-tight mb-4">
        Alexandra Quijano
      </h1>
      <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-6">
        Ingeniera de Software · Frontend
      </p>
      <p class="text-body text-lg leading-relaxed mb-10 max-w-lg mx-auto md:mx-0">
        Más de 7 años construyendo software de escala.<br />
        Hoy lo pongo al servicio de tu negocio.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
        <a href={`${base}#proyectos`} class="bg-accent hover:bg-indigo-500 text-white font-semibold px-8 py-3 rounded-full transition-colors text-center">
          Proyectos
        </a>
        <a href={`${base}#contacto`} class="border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold px-8 py-3 rounded-full transition-colors text-center">
          Contáctame
        </a>
      </div>
    </div>

    <!-- Illustration -->
    <div class="flex justify-center md:flex-shrink-0">
      <img
        src={`${base}images/hero_illustration.svg`}
        alt="Desarrolladora trabajando"
        class="w-64 md:w-80 lg:w-[35rem]"
        width="560"
        height="537"
        fetchpriority="high"
      />
    </div>

  </div>
</section>
