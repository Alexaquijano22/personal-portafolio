---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const techs = [
  { name: 'HTML 5',      img: `${base}images/tech/html5-original.svg` },
  { name: 'CSS 3',       img: `${base}images/tech/css3-original.svg` },
  { name: 'Sass',        img: `${base}images/tech/sass-original.svg` },
  { name: 'JavaScript',  img: `${base}images/tech/javascript-original.svg` },
  { name: 'TypeScript',  img: `${base}images/tech/typescript-original.svg` },
  { name: 'React',       img: `${base}images/tech/react-original.svg` },
  { name: 'Angular',     img: `${base}images/tech/angular-original.svg` },
  { name: 'Bootstrap',   img: `${base}images/tech/bootstrap-original.svg` },
  { name: 'Material UI', img: `${base}images/tech/materialui-original.svg` },
  { name: 'Git',         img: `${base}images/Logo-de-Git.png` },
];
---
<section id="stack" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">Herramientas modernas y probadas</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-primary mb-4">Tecnologías que uso</h2>
      <p class="text-body max-w-xl mx-auto">Para construir sitios rápidos, seguros y fáciles de mantener.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {techs.map(tech => (
        <div class="flex flex-col items-center gap-3 p-6 border border-gray-200 rounded-2xl hover:border-accent hover:shadow-md transition-all cursor-default group">
          <img src={tech.img} alt={tech.name} class="w-14 h-14 object-contain" width="56" height="56" loading="lazy" />
          <span class="text-sm font-semibold text-body group-hover:text-accent transition-colors">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
