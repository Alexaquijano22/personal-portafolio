---
const services = [
  {
    title: 'Landing Pages',
    description: 'Páginas diseñadas para convertir: rápidas, mobile-first y optimizadas para buscadores. Construidas con el rigor técnico del software empresarial.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
  },
  {
    title: 'Aplicaciones Web',
    description: 'Herramientas digitales a medida — reservas, catálogos, paneles — con arquitectura que aguanta el crecimiento de tu negocio.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>`,
  },
  {
    title: 'Tiendas Online',
    description: 'Tu tienda lista para vender desde el día uno: catálogo, carrito y pagos integrados, sin complejidad técnica de tu lado.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>`,
  },
  {
    title: 'Presencia Digital',
    description: 'Sitio web profesional + SEO básico para que tus clientes te encuentren en Google cuando más te necesitan.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>`,
  },
];
---
<section id="servicios" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">¿Qué puedo hacer por tu negocio?</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-primary">Servicios</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map(service => (
        <div class="bg-white rounded-2xl p-8 border border-gray-100 hover:border-accent hover:shadow-lg transition-all group">
          <div class="text-accent mb-5" set:html={service.icon} />
          <h3 class="text-xl font-bold text-primary mb-3 group-hover:text-accent transition-colors">{service.title}</h3>
          <p class="text-body leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
