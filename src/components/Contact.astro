---
<section id="contacto" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">¿Tenés un negocio que merece una web profesional?</p>
      <h2 class="text-3xl md:text-4xl font-extrabold text-primary">Hablemos</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto">
      <!-- Contact info -->
      <div>
        <h3 class="text-xl font-bold text-primary mb-3">Contactame</h3>
        <p class="text-body mb-8 leading-relaxed">
          Contame sobre tu negocio y lo que necesitás. Sin formularios raros ni presupuestos automáticos — solo una conversación real.
        </p>
        <ul class="flex flex-col gap-5">
          {socialLinks.map(link => (
            <li>
              {link.href ? (
                <a
                  href={link.href}
                  target={link.href.startsWith('mailto') ? undefined : '_blank'}
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 text-body hover:text-accent transition-colors group"
                >
                  <span class="text-accent bg-surface p-2 rounded-lg group-hover:bg-accent group-hover:text-white transition-colors">
                    <Fragment set:html={link.icon} />
                  </span>
                  <span class="font-medium">{link.display}</span>
                </a>
              ) : (
                <span class="flex items-center gap-3 text-body">
                  <span class="text-accent bg-surface p-2 rounded-lg">
                    <Fragment set:html={link.icon} />
                  </span>
                  <span class="font-medium">{link.display}</span>
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>

      <!-- Form -->
      <div>
        <h3 class="text-xl font-bold text-primary mb-6">Escribime</h3>
        <form
          method="POST"
          action="https://formspree.io/f/YOUR_FORM_ID"
          class="flex flex-col gap-5"
        >
          <div>
            <label for="nombre" class="block text-sm font-semibold text-primary mb-2">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              placeholder="Tu nombre"
              class="w-full px-4 py-3 bg-surface border border-gray-200 rounded-xl text-body placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent transition"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-primary mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="tu@email.com"
              class="w-full px-4 py-3 bg-surface border border-gray-200 rounded-xl text-body placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent transition"
            />
          </div>
          <div>
            <label for="mensaje" class="block text-sm font-semibold text-primary mb-2">Mensaje</label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows="5"
              placeholder="¿En qué puedo ayudarte?"
              class="w-full px-4 py-3 bg-surface border border-gray-200 rounded-xl text-body placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent transition resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="bg-accent hover:bg-indigo-500 text-white font-semibold py-3 px-8 rounded-full transition-colors"
          >
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
